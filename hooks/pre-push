#!/usr/bin/env bash
# GLOBAL PRE-PUSH HOOK v3.0.0 — Industry Standard
# Runs typecheck ONLY on main/master branch pushes.
# Feature branches: pass through immediately (CI handles it).
# Philosophy: fast local loop, CI is the source of truth.

set -uo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
cd "$REPO_ROOT"

# ── Read what branch is being pushed ─────────────────────────────
# Git passes remote refs via stdin: <local-ref> <local-sha> <remote-ref> <remote-sha>
PUSH_TARGET_BRANCH=""
while read -r local_ref local_sha remote_ref remote_sha; do
  PUSH_TARGET_BRANCH=$(echo "$remote_ref" | sed 's|refs/heads/||')
done

# ── Only run checks when pushing to main/master ──────────────────
if [[ "$PUSH_TARGET_BRANCH" != "main" && "$PUSH_TARGET_BRANCH" != "master" ]]; then
  # Feature branch push — instant, trust CI
  exit 0
fi

# ── Main branch: typecheck only ──────────────────────────────────
detect_pm() {
  [ -f "pnpm-lock.yaml" ] && echo "pnpm" && return
  [ -f "bun.lockb" ] || [ -f "bun.lock" ] && echo "bun" && return
  echo "npm"
}

has_script() {
  python3 -c "import json,sys; sys.exit(0 if '$1' in json.load(open('package.json')).get('scripts',{}) else 1)" 2>/dev/null
}

echo ""
echo "⚡ pre-push [main] — typecheck gate"
echo "────────────────────────────────────────────────"

ERRORS=0

# Node.js: typecheck only
if [ -f "package.json" ]; then
  PM=$(detect_pm)
  if has_script "typecheck"; then
    echo "  TypeScript typecheck..."
    if ! $PM run typecheck 2>&1; then
      echo "❌ typecheck failed — fix before pushing to main"
      ERRORS=$((ERRORS + 1))
    else
      echo "✅ typecheck passed"
    fi
  fi
fi

# Flutter: analyze only (on main)
if [ -f "pubspec.yaml" ] && command -v flutter >/dev/null 2>&1; then
  echo "  Flutter analyze..."
  if ! flutter analyze --fatal-infos 2>&1; then
    echo "❌ flutter analyze failed"
    ERRORS=$((ERRORS + 1))
  else
    echo "✅ flutter analyze passed"
  fi
fi

echo "────────────────────────────────────────────────"
if [ $ERRORS -gt 0 ]; then
  echo "🚫 Push to main blocked — fix errors above"
  echo "   Bypass: git push --no-verify"
  exit 1
fi
echo "🚀 Pushing to main..."
exit 0
